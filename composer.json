{
    "name": "scriptdevelop/instagram-api-manager",
    "title": "Composer Package",
    "version": "1.1.0",
    "description": "Paquete Laravel 12, para administrar y manejar múltiples cuentas de Instagram a través de su API oficial.",
    "keywords": [
        "instagram",
        "laravel",
        "api",
        "messaging",
        "chat",
        "notifications"
    ],
    "homepage": "https://github.com/djdang3r/instagram-api-manager",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0 || ^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.1",
        "orchestra/testbench": "^10.2",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "ScriptDevelop\\InstagramApiManager\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ScriptDevelop\\InstagramApiManager\\Providers\\InstagramServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "Wilfredo Perilla",
            "email": "wilfredoperilla@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-install-cmd": [
            "ScriptDevelop\\InstagramApiManager\\ComposerInstaller::postInstall"
        ],
        "post-update-cmd": [
            "ScriptDevelop\\InstagramApiManager\\ComposerInstaller::postInstall"
        ]
    }
}